<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>

<BorderPane stylesheets="@MainView.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.duan_admin.MainViewController">

    <center>
        <StackPane fx:id="rootPane" styleClass="background">

            <!-- MÀNN HÌNH ĐĂNG NHẬP -->
            <AnchorPane fx:id="loginPane" managed="true" visible="true">
                <StackPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

                    <!-- Ảnh nền full màn hình -->
                    <ImageView fx:id="loginBgImage" preserveRatio="false">
                        <image>
                            <Image url="@img.png" />
                        </image>
                    </ImageView>

                    <!-- Lớp gradient từ trong suốt → tối dần về phía phải -->
                    <Region style="-fx-background-color: linear-gradient(to right, transparent 20%, #0D0D14 55%);" />

                    <!-- Form đăng nhập nằm bên phải -->
                    <!-- Form đăng nhập nằm bên phải -->
                    <HBox alignment="CENTER_RIGHT" style="-fx-padding: 0 40 0 0;">
                        <VBox alignment="CENTER" minWidth="380" prefWidth="380" spacing="25" styleClass="login-card" HBox.hgrow="NEVER">
                            <padding>
                                <Insets bottom="40" left="40" right="40" top="40" />
                            </padding>

                            <!-- Logo cuộn phim + tên -->
                            <VBox alignment="CENTER" spacing="10">
                                <FontIcon iconLiteral="fas-compact-disc"
                                          iconSize="70"
                                          styleClass="login-logo-icon" />
                                <Label styleClass="logo-text" text="CINEVERSE" />
                                <Label styleClass="login-title" text="ADMINISTRATOR LOGIN" />
                            </VBox>

                            <Separator styleClass="form-divider" />

                            <!-- Tên đăng nhập -->
                            <VBox spacing="8">
                                <Label styleClass="field-label" text="Tên đăng nhập" />
                                <HBox alignment="CENTER_LEFT" styleClass="input-wrapper">
                                    <TextField fx:id="txtUsername" promptText="Nhập tài khoản quản trị" styleClass="input-inner" HBox.hgrow="ALWAYS" />
                                    <FontIcon iconLiteral="fas-user" iconSize="16" styleClass="input-icon" />
                                </HBox>
                            </VBox>

                            <!-- Mật khẩu -->
                            <VBox spacing="8">
                                <Label styleClass="field-label" text="Mật khẩu" />
                                <HBox alignment="CENTER_LEFT" styleClass="input-wrapper">
                                    <PasswordField fx:id="txtPassword" promptText="Nhập mật khẩu an toàn" styleClass="input-inner" HBox.hgrow="ALWAYS" />
                                    <FontIcon iconLiteral="fas-lock" iconSize="16" styleClass="input-icon" />
                                </HBox>
                            </VBox>

                            <HBox alignment="CENTER_LEFT">
                                <CheckBox styleClass="remember-me" text="Tin cậy trên thiết bị này" />
                            </HBox>

                            <Label fx:id="lblStatus" styleClass="status" />

                            <Button maxWidth="Infinity" onAction="#login" styleClass="submit-button" text="ĐĂNG NHẬP HỆ THỐNG" />
                        </VBox>
                    </HBox>

                </StackPane>
            </AnchorPane>

            <!-- DASHBOARD SAU KHI ĐĂNG NHẬP -->
            <BorderPane fx:id="dashboardPane" managed="false" visible="false">
                <left>
                    <VBox fx:id="sidebarPane" maxWidth="240" minWidth="240" prefWidth="240" spacing="15" styleClass="sidebar">

                        <padding>
                            <Insets bottom="20" left="10" right="10" top="20" />
                        </padding>

                        <!-- Logo -->
                        <VBox alignment="CENTER" spacing="5" style="-fx-padding: 10 0 10 0;">
                            <FontIcon iconColor="white" iconLiteral="fas-film" iconSize="40" styleClass="sidebar-logo-icon" />

                            <Label styleClass="sidebar-title" text="CINEVERSE" />

                            <Label styleClass="sidebar-subtitle" text="Admin Dashboard" />
                        </VBox>

                        <Separator styleClass="sidebar-divider" />

                        <!-- Menu -->
                        <VBox spacing="5">

                            <Button fx:id="btnTrangChu"
                                    styleClass="menu-button"
                                    text="Trang chủ"
                                    maxWidth="Infinity"
                                    onAction="#moTrangChu">
                                <graphic>
                                    <FontIcon iconLiteral="fas-home" iconSize="18" styleClass="menu-icon"/>
                                </graphic>
                            </Button>

                            <Button fx:id="btnThemPhim"
                                    styleClass="menu-button"
                                    text="Thêm phim"
                                    maxWidth="Infinity"
                                    onAction="#moThemPhim">
                                <graphic>
                                    <FontIcon iconLiteral="fas-film" iconSize="18" styleClass="menu-icon"/>
                                </graphic>
                            </Button>

                            <Button fx:id="btnThemRap"
                                    styleClass="menu-button"
                                    text="Thêm rạp chiếu"
                                    maxWidth="Infinity"
                                    onAction="#moThemRap">
                                <graphic>
                                    <FontIcon iconLiteral="fas-building" iconSize="18" styleClass="menu-icon"/>
                                </graphic>
                            </Button>

                            <Button fx:id="btnThemPhong"
                                    styleClass="menu-button"
                                    text="Thêm phòng chiếu"
                                    maxWidth="Infinity"
                                    onAction="#moThemPhong">
                                <graphic>
                                    <FontIcon iconLiteral="fas-door-open" iconSize="18" styleClass="menu-icon"/>
                                </graphic>
                            </Button>

                            <Button fx:id="btnThemSuat"
                                    styleClass="menu-button"
                                    text="Thêm suất chiếu"
                                    maxWidth="Infinity"
                                    onAction="#moThemSuat">
                                <graphic>
                                    <FontIcon iconLiteral="fas-clock" iconSize="18" styleClass="menu-icon"/>
                                </graphic>
                            </Button>

                            <Button fx:id="btnQuetQR"
                                    styleClass="menu-button"
                                    text="Quét mã QR"
                                    maxWidth="Infinity"
                                    onAction="#quetQR">
                                <graphic>
                                    <FontIcon iconLiteral="fas-qrcode" iconSize="18" styleClass="menu-icon"/>
                                </graphic>
                            </Button>

                            <Button fx:id="btnQuanTriDuLieu"
                                    styleClass="menu-button"
                                    text="Quản trị dữ liệu"
                                    maxWidth="Infinity"
                                    onAction="#moQuanTriDuLieu">
                                <graphic>
                                    <FontIcon iconLiteral="fas-database" iconSize="18" styleClass="menu-icon"/>
                                </graphic>
                            </Button>

                            <Button fx:id="btnQuanLyTaiKhoan"
                                    styleClass="menu-button"
                                    text="Quản lý tài khoản"
                                    maxWidth="Infinity"
                                    onAction="#moQuanLyTaiKhoan">
                                <graphic>
                                    <FontIcon iconLiteral="fas-user-shield" iconSize="18" styleClass="menu-icon"/>
                                </graphic>
                            </Button>

                        </VBox>

                        <!-- Đẩy nút Logout xuống dưới -->
                        <Region VBox.vgrow="ALWAYS" />

                        <Separator styleClass="sidebar-divider" />

                        <Button fx:id="btnLogout" maxWidth="Infinity" onAction="#logout" styleClass="logout-button" text="Đăng xuất" />

                    </VBox>
                </left>

                <center>
                    <StackPane fx:id="contentPane" styleClass="content-area" />
                </center>
            </BorderPane>

        </StackPane>
    </center>

</BorderPane>
