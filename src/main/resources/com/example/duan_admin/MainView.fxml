<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane stylesheets="@MainView.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.duan_admin.MainViewController">

    <top>
        <HBox fx:id="headerPane" styleClass="topbar">
            <VBox spacing="2">
                <Label styleClass="title" text="BẢNG ĐIỀU KHIỂN QUẢN TRỊ" />
                <Label styleClass="admin-title" text="CINEVERSE ADMIN" />
            </VBox>

            <Pane HBox.hgrow="ALWAYS" />

            <Label styleClass="admin-name" text="Xin chào Admin" />
        </HBox>
    </top>

    <center>
        <StackPane fx:id="rootPane" styleClass="background">

            <AnchorPane fx:id="loginPane" visible="true" managed="true" styleClass="background">
                <StackPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                    <VBox alignment="CENTER" maxWidth="420" maxHeight="500" spacing="25" styleClass="login-card">
                        <padding>
                            <Insets bottom="40" left="40" right="40" top="40" />
                        </padding>

                        <VBox alignment="CENTER" spacing="5">
                            <Label styleClass="logo-text" text="CINEVERSE" />
                            <Label styleClass="login-title" text="ADMINISTRATOR LOGIN" />
                        </VBox>

                        <Separator styleClass="form-divider" />

                        <VBox spacing="8">
                            <Label styleClass="field-label" text="Tên đăng nhập" />
                            <TextField fx:id="txtUsername" promptText="Nhập tài khoản quản trị" styleClass="input" />
                        </VBox>

                        <VBox spacing="8">
                            <Label styleClass="field-label" text="Mật khẩu" />
                            <PasswordField fx:id="txtPassword" promptText="Nhập mật khẩu an toàn" styleClass="input" />
                        </VBox>

                        <HBox alignment="CENTER_LEFT">
                            <CheckBox styleClass="remember-me" text="Ghi nhớ phiên đăng nhập" />
                        </HBox>

                        <Label fx:id="lblStatus" styleClass="status" />

                        <Button onAction="#login" maxWidth="Infinity" styleClass="submit-button" text="ĐĂNG NHẬP HỆ THỐNG" />
                    </VBox>
                </StackPane>
            </AnchorPane>
            <BorderPane fx:id="dashboardPane" visible="true" managed="true">

                <left>
                    <VBox fx:id="sidebarPane"
                          spacing="10"
                          prefWidth="240"
                          minWidth="240"
                          maxWidth="240"
                          styleClass="sidebar">

                        <Label styleClass="sidebar-logo" text="CINEVERSE NAVIGATION" />
                        <Separator styleClass="form-divider" />

                        <Button styleClass="menu-button" text="Thêm phim" onAction="#moThemPhim"/>
                        <Button styleClass="menu-button" text="Thêm rạp chiếu" onAction="#moThemRap"/>
                        <Button styleClass="menu-button" text="Thêm phòng chiếu" onAction="#moThemPhong"/>
                        <Button styleClass="menu-button" text="Thêm suất chiếu" onAction="#moThemSuat"/>
                        <Button styleClass="menu-button" text="Quét mã QR" onAction="#quetQR" />

                        <Pane VBox.vgrow="ALWAYS" />

                        <Button onAction="#logout" styleClass="logout-button" text="Đăng xuất" />
                    </VBox>
                </left>

                <center>
                    <StackPane fx:id="contentPane" styleClass="content-area">
                    </StackPane>
                </center>

            </BorderPane>

        </StackPane>
    </center>

</BorderPane>