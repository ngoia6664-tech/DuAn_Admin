<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane stylesheets="@MainView.css" styleClass="content-area" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.duan_admin.HomeController">
    <VBox spacing="25" alignment="TOP_LEFT">
        <padding>
            <Insets top="30" right="30" bottom="30" left="30"/>
        </padding>

        <VBox spacing="5">
            <Label text="TỔNG QUAN HỆ THỐNG" styleClass="form-title" style="-fx-text-fill: #ffffff; -fx-font-size: 24px; -fx-font-weight: bold;"/>
            <Label text="Chào mừng trở lại! Dưới đây là trạng thái rạp chiếu phim hiện tại của bạn." style="-fx-text-fill: #aaaaaa; -fx-font-size: 13px;"/>
        </VBox>

        <HBox spacing="20">
            <VBox spacing="10" style="-fx-background-color: #1e1e2d; -fx-padding: 20; -fx-background-radius: 10; -fx-border-color: #32324d; -fx-border-radius: 10;" HBox.hgrow="ALWAYS">
                <Label text="Tổng doanh thu hôm nay" style="-fx-text-fill: #8888aa; -fx-font-size: 14px;"/>
                <Label fx:id="lblDoanhThu" text="Đang tải..." style="-fx-text-fill: #00ffcc; -fx-font-size: 28px; -fx-font-weight: bold;"/>
            </VBox>

            <VBox spacing="10" style="-fx-background-color: #1e1e2d; -fx-padding: 20; -fx-background-radius: 10; -fx-border-color: #32324d; -fx-border-radius: 10;" HBox.hgrow="ALWAYS">
                <Label text="Vé đã bán" style="-fx-text-fill: #8888aa; -fx-font-size: 14px;"/>
                <Label fx:id="lblVeDaBan" text="Đang tải..." style="-fx-text-fill: #ff3366; -fx-font-size: 28px; -fx-font-weight: bold;"/>
            </VBox>

            <VBox spacing="10" style="-fx-background-color: #1e1e2d; -fx-padding: 20; -fx-background-radius: 10; -fx-border-color: #32324d; -fx-border-radius: 10;" HBox.hgrow="ALWAYS">
                <Label text="Suất chiếu đang chạy" style="-fx-text-fill: #8888aa; -fx-font-size: 14px;"/>
                <Label fx:id="lblSuatChieu" text="Đang tải..." style="-fx-text-fill: #ffcc00; -fx-font-size: 28px; -fx-font-weight: bold;"/>
            </VBox>
        </HBox>
    </VBox>
</StackPane>
