<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.duan_admin.AccountInfoController"
      spacing="15" styleClass="form-container" stylesheets="@CSSChung.css">
    <padding><Insets top="20" right="40" bottom="20" left="40"/></padding>

    <!-- Header với icon -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <FontIcon iconLiteral="fas-user-circle" iconSize="28" styleClass="header-icon"/>
        <Label text="THÔNG TIN TÀI KHOẢN" styleClass="header-text"/>
    </HBox>
    <Separator/>

    <!-- Username -->
    <VBox spacing="5">
        <HBox spacing="6" alignment="CENTER_LEFT">
            <FontIcon iconLiteral="fas-user" iconSize="14" styleClass="field-icon"/>
            <Label text="Tên đăng nhập" styleClass="field-label"/>
        </HBox>
        <TextField fx:id="txtUsername" editable="false" styleClass="input-readonly"/>
    </VBox>

    <!-- Họ tên -->
    <VBox spacing="5">
        <HBox spacing="6" alignment="CENTER_LEFT">
            <FontIcon iconLiteral="fas-id-card" iconSize="14" styleClass="field-icon"/>
            <Label text="Họ và tên" styleClass="field-label"/>
        </HBox>
        <TextField fx:id="txtFullName" editable="false" styleClass="input-readonly"/>
    </VBox>

    <!-- Role -->
    <VBox spacing="5">
        <HBox spacing="6" alignment="CENTER_LEFT">
            <FontIcon iconLiteral="fas-shield-alt" iconSize="14" styleClass="field-icon"/>
            <Label text="Quyền hệ thống" styleClass="field-label"/>
        </HBox>
        <TextField fx:id="txtRole" editable="false" styleClass="input-readonly"/>
    </VBox>

    <Separator/>

    <Button onAction="#switchToChangePassword" styleClass="nav-button">
        <graphic>
            <HBox spacing="8" alignment="CENTER">
                <FontIcon iconLiteral="fas-key" iconSize="14"/>
                <Label text="Đổi mật khẩu"/>
            </HBox>
        </graphic>
    </Button>
</VBox>