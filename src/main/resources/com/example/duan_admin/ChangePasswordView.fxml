<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.duan_admin.ChangePasswordController"
      spacing="15" styleClass="form-container" stylesheets="@CSSChung.css">
    <padding><Insets top="20" right="40" bottom="20" left="40"/></padding>

    <!-- Header -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <FontIcon iconLiteral="fas-lock" iconSize="28" styleClass="header-icon"/>
        <Label text="ĐỔI MẬT KHẨU" styleClass="header-text"/>
    </HBox>
    <Separator/>

    <!-- Mật khẩu hiện tại -->
    <VBox spacing="5">
        <HBox spacing="6" alignment="CENTER_LEFT">
            <FontIcon iconLiteral="fas-key" iconSize="14" styleClass="field-icon"/>
            <Label text="Mật khẩu hiện tại" styleClass="field-label"/>
        </HBox>
        <PasswordField fx:id="txtOldPass" styleClass="input"/>
    </VBox>

    <!-- Mật khẩu mới -->
    <VBox spacing="5">
        <HBox spacing="6" alignment="CENTER_LEFT">
            <FontIcon iconLiteral="fas-lock-open" iconSize="14" styleClass="field-icon"/>
            <Label text="Mật khẩu mới" styleClass="field-label"/>
        </HBox>
        <PasswordField fx:id="txtNewPass" styleClass="input"/>
    </VBox>

    <!-- Xác nhận mật khẩu -->
    <VBox spacing="5">
        <HBox spacing="6" alignment="CENTER_LEFT">
            <FontIcon iconLiteral="fas-check-circle" iconSize="14" styleClass="field-icon"/>
            <Label text="Xác nhận mật khẩu mới" styleClass="field-label"/>
        </HBox>
        <PasswordField fx:id="txtConfirmPass" styleClass="input"/>
    </VBox>

    <Label fx:id="lblStatus" styleClass="status" wrapText="true"/>

    <Separator/>

    <!-- Nút cập nhật -->
    <Button onAction="#handleUpdatePassword" styleClass="submit-button" maxWidth="Infinity">
        <graphic>
            <HBox spacing="8" alignment="CENTER">
                <FontIcon iconLiteral="fas-save" iconSize="14"/>
                <Label text="CẬP NHẬT MẬT KHẨU"/>
            </HBox>
        </graphic>
    </Button>

    <!-- Nút quay lại -->
    <Button onAction="#goBack" styleClass="nav-link-button">
        <graphic>
            <HBox spacing="8" alignment="CENTER">
                <FontIcon iconLiteral="fas-arrow-left" iconSize="13"/>
                <Label text="Quay lại thông tin tài khoản"/>
            </HBox>
        </graphic>
    </Button>
</VBox>