<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane stylesheets="@ThemRap.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.duan_admin.ThemRapController">

    <VBox alignment="CENTER" spacing="20" styleClass="form-card">

        <padding>
            <Insets bottom="30" left="35" right="35" top="30" />
        </padding>

        <Label styleClass="title" text="THÊM RẠP CHIẾU" />

        <Label styleClass="subtitle" text="Nhập thông tin rạp phim" />

        <!-- Tên rạp -->

        <VBox alignment="CENTER_LEFT" spacing="6">

            <Label styleClass="field-label" text="Tên rạp" />

            <TextField fx:id="txtTenRap" promptText="Nhập tên rạp phim" styleClass="input" />
        </VBox>

        <!-- Địa chỉ -->

        <VBox alignment="CENTER_LEFT" spacing="6">

            <Label styleClass="field-label" text="Địa chỉ" />

            <TextArea fx:id="txtDiaChi" prefRowCount="4" promptText="Nhập địa chỉ rạp" styleClass="input" wrapText="true" />
        </VBox>

        <!-- BUTTON -->

        <HBox alignment="CENTER" spacing="15">

            <Button onAction="#themRap" styleClass="submit-button" text="THÊM RẠP" />

            <Button onAction="#thoat" styleClass="exit-button" text="THOÁT" />

        </HBox>

    </VBox>

</StackPane>
